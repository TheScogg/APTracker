rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return signedIn() && currentUid() == userId;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(currentUid());
    }

    function userDoc() {
      return get(userPath());
    }

    function hasPlantAccess() {
      return signedIn()
        && exists(userPath())
        && userDoc().data.plantIds is list
        && userDoc().data.plantIds.size() > 0;
    }

    function memberPath(plantId) {
      return /databases/$(database)/documents/plants/$(plantId)/members/$(currentUid());
    }

    function memberDoc(plantId) {
      return get(memberPath(plantId));
    }

    // A user is a plant member if their member doc exists and isActive == true.
    // Note: the app writes { isActive: true, role: "admin"|"editor"|"viewer" }.
    function isPlantMember(plantId) {
      return signedIn()
        && exists(memberPath(plantId))
        && memberDoc(plantId).data.isActive == true;
    }

    function memberRole(plantId) {
      return memberDoc(plantId).data.role;
    }

    function isAdmin(plantId) {
      return isPlantMember(plantId) && memberRole(plantId) == "admin";
    }

    function isEditorOrAbove(plantId) {
      return isPlantMember(plantId)
        && (memberRole(plantId) == "admin" || memberRole(plantId) == "editor");
    }

    function conversationMemberPath(plantId, conversationId, userId) {
      return /databases/$(database)/documents/plants/$(plantId)/conversations/$(conversationId)/members/$(userId);
    }

    function conversationPath(plantId, conversationId) {
      return /databases/$(database)/documents/plants/$(plantId)/conversations/$(conversationId);
    }

    function isConversationMember(plantId, conversationId) {
      return signedIn() && exists(conversationMemberPath(plantId, conversationId, currentUid()));
    }

    function isConversationParticipant(plantId, conversationId) {
      return signedIn()
        && (isConversationMember(plantId, conversationId)
          || (exists(conversationPath(plantId, conversationId))
              && get(conversationPath(plantId, conversationId)).data.memberIds.hasAny([currentUid()]))
          || (existsAfter(conversationPath(plantId, conversationId))
              && getAfter(conversationPath(plantId, conversationId)).data.memberIds.hasAny([currentUid()])));
    }

    function isConversationCreator(plantId, conversationId) {
      return signedIn()
        && ((exists(conversationPath(plantId, conversationId))
            && get(conversationPath(plantId, conversationId)).data.createdBy.uid == currentUid())
            || (existsAfter(conversationPath(plantId, conversationId))
            && getAfter(conversationPath(plantId, conversationId)).data.createdBy.uid == currentUid()));
    }

    function conversationMemberListHasUser(plantId, conversationId, userId) {
      return (exists(conversationPath(plantId, conversationId))
              && get(conversationPath(plantId, conversationId)).data.memberIds.hasAny([userId]))
        || (existsAfter(conversationPath(plantId, conversationId))
              && getAfter(conversationPath(plantId, conversationId)).data.memberIds.hasAny([userId]));
    }

    // Only the plantIds field is being touched (used when adding/removing a user from a plant).
    function onlyUpdatesPlantIds() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['plantIds']);
    }

    function onlyUpdatesOwnRolePrefs() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['jobRoleKeys', 'jobFeeds', 'alertCategorySubscriptions', 'updatedAt', 'updatedBy']);
    }

    function onlyRemovesSelfFromRecipients() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['recipientUserIds'])
        && resource.data.recipientUserIds is list
        && request.resource.data.recipientUserIds is list
        && resource.data.recipientUserIds.hasAny([currentUid()])
        && !request.resource.data.recipientUserIds.hasAny([currentUid()])
        && request.resource.data.recipientUserIds.size() + 1 == resource.data.recipientUserIds.size();
    }

    function isValidScheduleDate(dateStr) {
      return dateStr is string
        && dateStr.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function validScheduleSection(section) {
      return section in ['page1', 'page2', 'northBayChanges', 'southBayChanges'];
    }

    function validDailyScheduleDoc(scheduleDate, expectedPlantId) {
      return request.resource.data.keys().hasAll([
          'scheduleDate', 'shift', 'lineSpeed', 'totalPlannedPcs',
          'sourceFileName', 'sourceFileType', 'status', 'notes',
          'page1Count', 'page2Count', 'northBayChangesCount', 'southBayChangesCount',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.scheduleDate == scheduleDate
        && isValidScheduleDate(request.resource.data.scheduleDate)
        && request.resource.data.shift is number
        && (request.resource.data.lineSpeed == null || request.resource.data.lineSpeed is number)
        && (request.resource.data.totalPlannedPcs == null || request.resource.data.totalPlannedPcs is number)
        && request.resource.data.sourceFileName is string
        && request.resource.data.sourceFileType is string
        && request.resource.data.status is string
        && request.resource.data.notes is string
        && (!request.resource.data.keys().hasAny(['plantId'])
            || (request.resource.data.plantId is string
                && (expectedPlantId == null || request.resource.data.plantId == expectedPlantId)))
        && request.resource.data.page1Count is number
        && request.resource.data.page2Count is number
        && request.resource.data.northBayChangesCount is number
        && request.resource.data.southBayChangesCount is number;
    }

    function validScheduleRowDoc(scheduleDate, section, rowId, expectedPlantId) {
      return request.resource.data.keys().hasAll([
          'rowId', 'scheduleDate', 'shift', 'section', 'press',
          'partStorageLocation', 'partNumber', 'description', 'cavity',
          'doh', 'labelsPerShift', 'mc', 'notes', 'displayOrder', 'isChange',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.rowId == rowId
        && request.resource.data.scheduleDate == scheduleDate
        && isValidScheduleDate(request.resource.data.scheduleDate)
        && request.resource.data.section == section
        && validScheduleSection(section)
        && request.resource.data.shift is number
        && request.resource.data.press is string
        && request.resource.data.partStorageLocation is list
        && request.resource.data.partNumber is string
        && request.resource.data.description is string
        && (!request.resource.data.keys().hasAny(['plantId'])
            || (request.resource.data.plantId is string
                && (expectedPlantId == null || request.resource.data.plantId == expectedPlantId)))
        && request.resource.data.cavity is string
        && (request.resource.data.doh == null || request.resource.data.doh is number)
        && (request.resource.data.labelsPerShift == null || request.resource.data.labelsPerShift is number)
        && request.resource.data.mc is string
        && request.resource.data.notes is string
        && request.resource.data.displayOrder is number
        && request.resource.data.isChange is bool;
    }

    // ── User profiles ──
    match /users/{userId} {
      // Users can always read/write their own profile.
      allow read, write: if isSelf(userId);
      // Any signed-in user may update another user's plantIds array
      // (needed when an admin adds/removes someone from a plant).
      allow update: if signedIn() && onlyUpdatesPlantIds();
    }

    // ── User lookup index (email → uid mapping, written on sign-in) ──
    match /userLookup/{email} {
      // Any signed-in user may read (needed for admin invite-by-email lookup).
      allow read: if signedIn();
      // A user may only write their own lookup record (uid in doc must match caller).
      allow write: if signedIn() && request.resource.data.uid == currentUid();
    }

    // ── Plants ──
    match /plants/{plantId} {
      // Any active member can read plant metadata.
      allow read: if isPlantMember(plantId);

      // Any signed-in user can create a plant (they will also create a member doc
      // for themselves in the same batch via _initNewPlant).
      allow create: if signedIn();

      // Only admins can update or delete a plant.
      allow update: if isAdmin(plantId);
      allow delete: if isAdmin(plantId);

      // ── Members ──
      match /members/{userId} {
        // Active members can see the full member list.
        allow read: if isPlantMember(plantId);

        // Admins can create/update/delete any member doc.
        allow create, update, delete: if isAdmin(plantId);

        // A user may create their own initial admin member doc when setting up
        // a new plant (the plant create and member create happen in the same batch).
        allow create: if isSelf(userId)
          && request.resource.data.role == "admin"
          && request.resource.data.isActive == true;

        // Users can update only their own alert-role preferences.
        allow update: if isSelf(userId)
          && isPlantMember(plantId)
          && onlyUpdatesOwnRolePrefs();
      }

      // ── Config (statuses, presses) ──
      match /config/{configId} {
        allow read: if isPlantMember(plantId);
        allow write: if isAdmin(plantId);
      }

      // ── Press Notes ──
      match /pressNotes/{noteId} {
        allow read: if isPlantMember(plantId);
        allow create: if isEditorOrAbove(plantId)
                      && request.resource.data.createdBy.uid == currentUid();
        allow delete: if isAdmin(plantId)
                      || (signedIn() && resource.data.createdBy.uid == currentUid());
        allow update: if false;
      }

      // ── Conversations ──
      match /conversations/{conversationId} {
        allow read: if isPlantMember(plantId)
                    && (resource.data.memberIds.hasAny([currentUid()])
                        || isConversationMember(plantId, conversationId));
        allow create: if isPlantMember(plantId)
                      && request.resource.data.plantId == plantId
                      && request.resource.data.memberIds is list
                      && request.resource.data.memberIds.size() >= 2
                      && request.resource.data.memberIds.hasAny([currentUid()]);
        allow update: if isConversationParticipant(plantId, conversationId)
                      && request.resource.data.plantId == resource.data.plantId
                      && request.resource.data.createdAt == resource.data.createdAt
                      && request.resource.data.createdBy == resource.data.createdBy
                      && request.resource.data.memberIds == resource.data.memberIds
                      && request.resource.data.memberCount == resource.data.memberCount
                      && request.resource.data.type == resource.data.type
                      && request.resource.data.pressId == resource.data.pressId;
        allow delete: if isAdmin(plantId);

        match /messages/{messageId} {
          allow read: if isConversationParticipant(plantId, conversationId);
          allow create: if isConversationParticipant(plantId, conversationId)
                        && request.resource.data.sender.uid == currentUid()
                        && request.resource.data.plantId == plantId
                        && request.resource.data.conversationId == conversationId;
          allow update, delete: if isAdmin(plantId)
                                || (signedIn() && resource.data.sender.uid == currentUid());
        }

        match /members/{userId} {
          allow read: if isConversationParticipant(plantId, conversationId);
          allow create: if isAdmin(plantId)
                        || (isPlantMember(plantId)
                            && isSelf(userId)
                            && conversationMemberListHasUser(plantId, conversationId, userId))
                        || (isPlantMember(plantId)
                            && isConversationCreator(plantId, conversationId)
                            && conversationMemberListHasUser(plantId, conversationId, userId));
          allow update: if isAdmin(plantId)
                        || (isSelf(userId) && isConversationMember(plantId, conversationId));
          allow delete: if isAdmin(plantId);
        }
      }

      // ── Gamification config ──
      match /gamificationConfig/{configId} {
        allow read: if isPlantMember(plantId);
        allow write: if isAdmin(plantId);
      }

      // ── User game stats ──
      match /userGameStats/{userId} {
        allow read: if isPlantMember(plantId);
        allow create, update: if isEditorOrAbove(plantId) && userId == request.resource.data.userId;
        allow delete: if isAdmin(plantId);
      }

      // ── User badges ──
      match /userBadges/{userId} {
        allow read: if isPlantMember(plantId);
        allow create, update: if isEditorOrAbove(plantId) && isSelf(userId);
        allow delete: if isAdmin(plantId);
      }

      // ── Missions ──
      match /missions/{missionId} {
        allow read: if isPlantMember(plantId);
        allow write: if isAdmin(plantId);

        match /progress/{subjectId} {
          allow read: if isPlantMember(plantId);
          allow create, update: if isEditorOrAbove(plantId)
                                && request.resource.data.subjectId == currentUid();
          allow delete: if isAdmin(plantId);
        }
      }

      // ── Leaderboards ──
      match /leaderboards/{boardId} {
        allow read: if isPlantMember(plantId);
        allow write: if isAdmin(plantId);
      }

      // ── Game events (append-only) ──
      match /gameEvents/{eventId} {
        allow read: if isPlantMember(plantId);
        allow create: if isEditorOrAbove(plantId);
        allow update, delete: if false;
      }

      // ── Issues ──
      match /issues/{issueId} {
        allow read: if isPlantMember(plantId);
        allow create, update: if isEditorOrAbove(plantId);
        allow delete: if isAdmin(plantId);

        // Events are append-only audit trail.
        match /events/{eventId} {
          allow read: if isPlantMember(plantId);
          allow create: if isEditorOrAbove(plantId);
          allow update, delete: if false;
        }

        // Attachments
        match /attachments/{attachmentId} {
          allow read: if isPlantMember(plantId);
          allow create, update: if isEditorOrAbove(plantId);
          allow delete: if isAdmin(plantId)
                        || (signedIn() && resource.data.uploadedBy.uid == currentUid());
        }
      }

      // ── Role feed alerts (append-only routing records) ──
      match /roleFeedAlerts/{alertId} {
        allow read: if isPlantMember(plantId);
        // Created by status routing flow; require authenticated editor/admin access.
        allow create: if isEditorOrAbove(plantId)
                      && request.resource.data.issueId is string
                      && request.resource.data.feedKey is string
                      && request.resource.data.feedLabel is string
                      && request.resource.data.requiredJobRoleKeys is list
                      && request.resource.data.recipientUserIds is list
                      && request.resource.data.createdBy.uid == currentUid();
        // Keep updates immutable except recipients can remove themselves from recipientUserIds.
        allow update: if isAdmin(plantId)
                      || (signedIn()
                          && isPlantMember(plantId)
                          && onlyRemovesSelfFromRecipients());
        allow delete: if isAdmin(plantId)
                      || (signedIn() && resource.data.recipientUserIds.hasAny([currentUid()]));
      }

      // ── Plant-scoped daily schedules ──
      match /dailySchedules/{scheduleDate} {
        allow read: if isPlantMember(plantId);
        allow create, update: if isAdmin(plantId)
                              && isValidScheduleDate(scheduleDate)
                              && validDailyScheduleDoc(scheduleDate, plantId);
        allow delete: if false;

        match /{section}/{rowId} {
          allow read: if isPlantMember(plantId);
          allow create, update: if isAdmin(plantId)
                                && isValidScheduleDate(scheduleDate)
                                && validScheduleSection(section)
                                && validScheduleRowDoc(scheduleDate, section, rowId, plantId);
          allow delete: if isAdmin(plantId) && validScheduleSection(section);
        }
      }
    }

    // ── Global app config ──
    // Store catalog is global across plants.
    match /globalConfig/{configId} {
      allow read: if signedIn();
      // Keep writes limited to users that belong to at least one plant.
      // (Admin UI additionally gates this client-side to plant admins.)
      allow write: if hasPlantAccess();
    }

  }
}
