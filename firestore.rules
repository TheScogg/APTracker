rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function memberPath(plantId) {
      return /databases/$(database)/documents/plants/$(plantId)/members/$(currentUid());
    }

    function memberDoc(plantId) {
      return get(memberPath(plantId));
    }

    function isPlantMember(plantId) {
      return signedIn()
        && exists(memberPath(plantId))
        && memberDoc(plantId).data.status == "active";
    }

    function roleIs(plantId, role) {
      return isPlantMember(plantId) && memberDoc(plantId).data.role == role;
    }

    function isOwner(plantId) {
      return roleIs(plantId, "owner");
    }

    function canEditPlant(plantId) {
      return roleIs(plantId, "owner") || roleIs(plantId, "editor");
    }

    function isSelf(userId) {
      return signedIn() && currentUid() == userId;
    }

    // ── Users ──
    match /users/{userId} {
      allow read, write: if isSelf(userId);
    }

    // ── Plants ──
    match /plants/{plantId} {
      // Plant metadata should be readable by active members.
      allow read: if isPlantMember(plantId);

      // A signed-in user can create a plant if they are the creator.
      allow create: if signedIn()
                    && request.resource.data.createdBy == currentUid();

      // Owners and editors can update plant-level metadata.
      allow update: if canEditPlant(plantId);

      // Deleting a plant is owner-only.
      allow delete: if isOwner(plantId);

      // ── Members ──
      match /members/{userId} {
        allow read: if isPlantMember(plantId);

        // Only owners can create/update/delete members, except that the plant
        // creator can create their own owner membership in the same batch
        // where the plant is created.
        allow create: if (
          isOwner(plantId)
          || (
            isSelf(userId)
            && request.resource.data.role == "owner"
            && request.resource.data.status == "active"
            && getAfter(/databases/$(database)/documents/plants/$(plantId)).data.createdBy == currentUid()
          )
        );

        allow update, delete: if isOwner(plantId);
      }

      // ── Config ──
      match /config/{configId} {
        allow read: if isPlantMember(plantId);
        allow write: if canEditPlant(plantId);
      }

      // ── Issues ──
      match /issues/{issueId} {
        allow read: if isPlantMember(plantId);
        allow create, update: if canEditPlant(plantId);
        allow delete: if isOwner(plantId);

        // Events are append-only audit trail.
        match /events/{eventId} {
          allow read: if isPlantMember(plantId);
          allow create: if canEditPlant(plantId);
          allow update, delete: if false;
        }

        // Attachments can be removed by uploader or owner.
        match /attachments/{attachmentId} {
          allow read: if isPlantMember(plantId);
          allow create, update: if canEditPlant(plantId);
          allow delete: if isOwner(plantId)
                        || (signedIn() && resource.data.uploadedBy.uid == currentUid());
        }
      }
    }
  }
}
